macro(_check_dep_target DEP_NAME)
	if(NOT TARGET deps::${DEP_NAME})
		if(TARGET ${DEP_NAME})
			add_library(deps::${DEP_NAME} ALIAS ${DEP_NAME})
		elseif(TARGET ${DEP_NAME}::${DEP_NAME})
			add_library(deps::${DEP_NAME} ALIAS ${DEP_NAME}::${DEP_NAME})
		elseif(TARGET ${DEP_NAME}::${DEP_NAME}-static)
			add_library(deps::${DEP_NAME} ALIAS ${DEP_NAME}::${DEP_NAME}-static)
		elseif(TARGET PkgConfig::${DEP_NAME})
			add_library(deps::${DEP_NAME} ALIAS PkgConfig::${DEP_NAME})
		endif()
	endif()
endmacro()

function(se_add_dependency TARGET_NAME DEP_NAME)
	get_target_property(TARGET_TYPE ${TARGET_NAME} TYPE)
	if(TARGET_TYPE STREQUAL "INTERFACE_LIBRARY")
        set(LINK_SCOPE "INTERFACE")
    else()
        set(LINK_SCOPE "PRIVATE")
    endif()

	if(TARGET deps::${DEP_NAME})
		target_link_libraries(${TARGET_NAME} ${LINK_SCOPE} deps::${DEP_NAME})
		return()
	endif()

	set(DEP_SCRIPT "${CMAKE_CURRENT_SOURCE_DIR}/cmake/deps/${DEP_NAME}.cmake")
	if(NOT EXISTS ${DEP_SCRIPT})
        message(FATAL_ERROR "Dependency definition not found at ${DEP_SCRIPT}")
    endif()
	include(${DEP_SCRIPT})
	_check_dep_target(${DEP_NAME})

	if(TARGET deps::${DEP_NAME})
		target_link_libraries(${TARGET_NAME} ${LINK_SCOPE} deps::${DEP_NAME})
		return()
	endif()

	if(SE_DEPS STREQUAL "system" OR SE_DEPS STREQUAL "fallback")
		cmake_language(CALL _dep_system_${DEP_NAME})
		_check_dep_target(${DEP_NAME})
	endif()

	if(NOT TARGET deps::${DEP_NAME})
		if(SE_DEPS STREQUAL "source" OR SE_DEPS STREQUAL "fallback")
			cmake_language(CALL _dep_source_${DEP_NAME})
			_check_dep_target(${DEP_NAME})
		endif()
	endif()

	if(NOT TARGET deps::${DEP_NAME})
		message(FATAL_ERROR "Failed to resolve dependency: ${DEP_NAME}")
		return()
	endif()

	target_link_libraries(${TARGET_NAME} ${LINK_SCOPE} deps::${DEP_NAME})
endfunction()
