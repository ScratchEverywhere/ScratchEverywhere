set(SE_FORCE_SOURCE_libdlgmod TRUE)
function(_dep_source_libdlgmod)
	if(NOT DEFINED libdlgmod_SOURCE_DIR)
		include("${CMAKE_CURRENT_SOURCE_DIR}/cmake/CPM.cmake")
		CPMAddPackage(
			NAME libdlgmod
			GITHUB_REPOSITORY samuelvenable/libdlgmod
			GIT_TAG main
		)
	endif()
	# compiler
	if(CMAKE_SYSTEM_NAME STREQUAL "Windows")
		add_library(libdlgmod STATIC "${libdlgmod_SOURCE_DIR}/libdlgmod/win32/libdlgmod.cpp" "${libdlgmod_SOURCE_DIR}/libdlgmod/general/apiprocess/process.cpp" "${libdlgmod_SOURCE_DIR}/libdlgmod/general/xprocess.cpp")
		target_include_directories(libdlgmod PUBLIC "${libdlgmod_SOURCE_DIR}/libdlgmod/general" "${libdlgmod_SOURCE_DIR}")
		target_compile_definitions(libdlgmod PUBLIC PROCESS_GUIWINDOW_IMPL NULLIFY_STDERR)
		set_target_properties(libdlgmod PROPERTIES CXX_STANDARD 17 CXX_STANDARD_REQUIRED ON POSITION_INDEPENDENT_CODE TRUE)
	elseif(CMAKE_SYSTEM_NAME STREQUAL "Darwin")
		add_library(libdlgmod STATIC "${libdlgmod_SOURCE_DIR}/libdlgmod/macos/libdlgmod.mm")
		target_include_directories(libdlgmod PUBLIC "${libdlgmod_SOURCE_DIR}/libdlgmod/general" "${libdlgmod_SOURCE_DIR}")
		target_compile_definitions(libdlgmod PUBLIC PROCESS_GUIWINDOW_IMPL NULLIFY_STDERR)
		set_target_properties(libdlgmod PROPERTIES OBJCXX_STANDARD 17 OBJCXX_STANDARD_REQUIRED ON POSITION_INDEPENDENT_CODE TRUE)
	elseif(CMAKE_SYSTEM_NAME STREQUAL "Linux" AND NOT WEBOS)
		add_library(libdlgmod STATIC "${libdlgmod_SOURCE_DIR}/libdlgmod/xlib/libdlgmod.cpp" "${libdlgmod_SOURCE_DIR}/libdlgmod/general/apiprocess/process.cpp" "${libdlgmod_SOURCE_DIR}/libdlgmod/general/xprocess.cpp" "${libdlgmod_SOURCE_DIR}/libdlgmod/general/lodepng.cpp")
		target_include_directories(libdlgmod PUBLIC "${libdlgmod_SOURCE_DIR}/libdlgmod/general" "${libdlgmod_SOURCE_DIR}")
		target_compile_definitions(libdlgmod PUBLIC PROCESS_GUIWINDOW_IMPL NULLIFY_STDERR)
		set_target_properties(libdlgmod PROPERTIES CXX_STANDARD 17 CXX_STANDARD_REQUIRED ON POSITION_INDEPENDENT_CODE TRUE)
	elseif(CMAKE_SYSTEM_NAME STREQUAL "FreeBSD")
		add_library(libdlgmod STATIC "${libdlgmod_SOURCE_DIR}/libdlgmod/xlib/libdlgmod.cpp" "${libdlgmod_SOURCE_DIR}/libdlgmod/general/apiprocess/process.cpp" "${libdlgmod_SOURCE_DIR}/libdlgmod/general/xprocess.cpp" "${libdlgmod_SOURCE_DIR}/libdlgmod/general/lodepng.cpp")
		target_include_directories(libdlgmod PUBLIC "${libdlgmod_SOURCE_DIR}/libdlgmod/general" "${libdlgmod_SOURCE_DIR}" "/usr/local/include")
		target_compile_definitions(libdlgmod PUBLIC PROCESS_GUIWINDOW_IMPL NULLIFY_STDERR)
		set_target_properties(libdlgmod PROPERTIES CXX_STANDARD 17 CXX_STANDARD_REQUIRED ON POSITION_INDEPENDENT_CODE TRUE)
	elseif(CMAKE_SYSTEM_NAME STREQUAL "DragonFly")
		add_library(libdlgmod STATIC "${libdlgmod_SOURCE_DIR}/libdlgmod/xlib/libdlgmod.cpp" "${libdlgmod_SOURCE_DIR}/libdlgmod/general/apiprocess/process.cpp" "${libdlgmod_SOURCE_DIR}/libdlgmod/general/xprocess.cpp" "${libdlgmod_SOURCE_DIR}/libdlgmod/general/lodepng.cpp")
		target_compile_options(libdlgmod PUBLIC -DPROCESS_GUIWINDOW_IMPL -DNULLIFY_STDERR)
		target_include_directories(libdlgmod PUBLIC "${libdlgmod_SOURCE_DIR}/libdlgmod/general" "${libdlgmod_SOURCE_DIR}" "/usr/local/include")
		set_target_properties(libdlgmod PROPERTIES CXX_STANDARD 17 CXX_STANDARD_REQUIRED ON POSITION_INDEPENDENT_CODE TRUE)
	elseif(CMAKE_SYSTEM_NAME STREQUAL "NetBSD")
		add_library(libdlgmod STATIC "${libdlgmod_SOURCE_DIR}/libdlgmod/xlib/libdlgmod.cpp" "${libdlgmod_SOURCE_DIR}/libdlgmod/general/apiprocess/process.cpp" "${libdlgmod_SOURCE_DIR}/libdlgmod/general/xprocess.cpp" "${libdlgmod_SOURCE_DIR}/libdlgmod/general/lodepng.cpp")
		target_include_directories(libdlgmod PUBLIC "${libdlgmod_SOURCE_DIR}/libdlgmod/general" "${libdlgmod_SOURCE_DIR}" "/usr/X11R7/include")
		target_compile_definitions(libdlgmod PUBLIC PROCESS_GUIWINDOW_IMPL NULLIFY_STDERR)
		set_target_properties(libdlgmod PROPERTIES CXX_STANDARD 17 CXX_STANDARD_REQUIRED ON POSITION_INDEPENDENT_CODE TRUE)
	elseif(CMAKE_SYSTEM_NAME STREQUAL "OpenBSD")
		add_library(libdlgmod STATIC "${libdlgmod_SOURCE_DIR}/libdlgmod/xlib/libdlgmod.cpp" "${libdlgmod_SOURCE_DIR}/libdlgmod/general/apiprocess/process.cpp" "${libdlgmod_SOURCE_DIR}/libdlgmod/general/xprocess.cpp" "${libdlgmod_SOURCE_DIR}/libdlgmod/general/lodepng.cpp")
		target_include_directories(libdlgmod PUBLIC "${libdlgmod_SOURCE_DIR}/libdlgmod/general" "${libdlgmod_SOURCE_DIR}" "/usr/X11R6/include")
		target_compile_definitions(libdlgmod PUBLIC PROCESS_GUIWINDOW_IMPL NULLIFY_STDERR)
		set_target_properties(libdlgmod PROPERTIES CXX_STANDARD 17 CXX_STANDARD_REQUIRED ON POSITION_INDEPENDENT_CODE TRUE)
	elseif(CMAKE_SYSTEM_NAME STREQUAL "SunOS")
		add_library(libdlgmod STATIC "${libdlgmod_SOURCE_DIR}/libdlgmod/xlib/libdlgmod.cpp" "${libdlgmod_SOURCE_DIR}/libdlgmod/general/apiprocess/process.cpp" "${libdlgmod_SOURCE_DIR}/libdlgmod/general/xprocess.cpp" "${libdlgmod_SOURCE_DIR}/libdlgmod/general/lodepng.cpp")
		target_include_directories(libdlgmod PUBLIC "${libdlgmod_SOURCE_DIR}/libdlgmod/general" "${libdlgmod_SOURCE_DIR}")
		target_compile_definitions(libdlgmod PUBLIC PROCESS_GUIWINDOW_IMPL NULLIFY_STDERR)
		set_target_properties(libdlgmod PROPERTIES CXX_STANDARD 17 CXX_STANDARD_REQUIRED ON POSITION_INDEPENDENT_CODE TRUE)
	endif()
	if(NOT WIN32)
		if(DEFINED SE_WINDOWING)
    		if(SE_WINDOWING STREQUAL "sdl1")
        		se_add_dependency(libdlgmod SDL)
        		target_compile_definitions(libdlgmod PUBLIC USE_SDL_POLLEVENT)
    		elseif(SE_WINDOWING STREQUAL "sdl2")
        		se_add_dependency(libdlgmod SDL2)
        		target_compile_definitions(libdlgmod PUBLIC USE_SDL2_POLLEVENT)
    		elseif(SE_WINDOWING STREQUAL "sdl3")
        		se_add_dependency(libdlgmod SDL3)
        		target_compile_definitions(libdlgmod PUBLIC USE_SDL3_POLLEVENT)
    		endif()
		endif()
	endif()
	# linker
	if(CMAKE_SYSTEM_NAME STREQUAL "Windows")
		target_link_libraries(libdlgmod PUBLIC ntdll gdiplus comctl32 shlwapi comdlg32 ole32 oleaut32 uuid)
	elseif(CMAKE_SYSTEM_NAME STREQUAL "Darwin")
		target_link_libraries(libdlgmod PUBLIC "-framework AppKit -framework UniformTypeIdentifiers")
	elseif(CMAKE_SYSTEM_NAME STREQUAL "Linux" AND NOT WEBOS)
		target_link_libraries(libdlgmod PUBLIC X11 pthread)
	elseif(CMAKE_SYSTEM_NAME STREQUAL "FreeBSD")
		target_link_directories(scratch-everywhere PRIVATE "/usr/local/lib")
		target_link_libraries(libdlgmod PUBLIC X11 kvm pthread)
	elseif(CMAKE_SYSTEM_NAME STREQUAL "DragonFly")
		target_link_directories(scratch-everywhere PRIVATE "/usr/local/lib")
		target_link_libraries(libdlgmod PUBLIC X11 kvm pthread)
	elseif(CMAKE_SYSTEM_NAME STREQUAL "NetBSD")
		target_link_directories(scratch-everywhere PRIVATE "/usr/X11R7/lib")
		target_link_libraries(libdlgmod PUBLIC X11 kvm pthread)
	elseif(CMAKE_SYSTEM_NAME STREQUAL "OpenBSD")
		target_link_directories(scratch-everywhere PRIVATE "/usr/X11R6/lib")
		target_link_libraries(libdlgmod PUBLIC X11 kvm pthread)
	elseif(CMAKE_SYSTEM_NAME STREQUAL "SunOS")
		target_link_libraries(libdlgmod PUBLIC X11 kvm proc pthread)
	endif()
endfunction()
